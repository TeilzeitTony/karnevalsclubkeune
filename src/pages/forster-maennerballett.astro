---
import Gallery from "../components/Gallery.astro";
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Forster Männerballett">

<PageHero
  title="Forster Männerballett"
  subtitle="Leidenschaft • Teamgeist • Show"
  image="/maennerballett-header.jpg"
/>

<section class="container">
  <h2>Aktuelles Programm</h2>
  <div class="program-card">
    <img src="/alice-im-wunderland.jpg" alt="Alice im Wunderland" />
    <div class="program-content">
      <span class="program-badge">Saison 2026 / 2027</span>
      <h3>Alice im Wunderland</h3>
      <p>Mit unserem aktuellen Showprogramm entführen wir das Publikum in eine fantasievolle Welt voller verrückter Charaktere, beeindruckender Kostüme und spektakulärer Choreografien.</p>
    </div>
  </div>
</section>

<section class="container">
  <h2>Trainingszeiten</h2>
  <div class="info-box">
    <p><strong>Dienstag</strong></p>
    <p>🕖 19:00 - 20:00 Uhr </p>
    <p>📍 Sportplatz Keune (Forst) | Schacksdorfer Straße 45</p>
  </div>
  <div class="info-box" style="margin-top:20px;">
    <p><strong>Sonntag</strong></p>
    <p>🕙 10:00 – 12:00 Uhr</p>
    <p>📍 Tanzschule Fritsche (Cottbus) | Rudolf-Breitscheid-Straße 11 </p>
  </div>
</section>

<section class="container">

  <h2>Unser aktueller Werbeflyer</h2>

  <div class="flyer-card">

    <img
      src="/galerie/maennerballett/flyer/maennerballett-flyer.jpg"
      alt="Werbeflyer Forster Männerballett"
    />

  </div>

</section>

<section class="container">
  <h2>Unsere Erfolge</h2>
  <div class="success-grid">
    <div class="success-card"><span class="success-icon">🥈</span><h3>Ostdeutscher Vizemeister</h3><p>Hanau 2026</p></div>
    <div class="success-card"><span class="success-icon">🏆</span><h3>Deutsche Meisterschaft</h3><p>3. Platz Kategorie Ü35</p></div>
    <div class="success-card"><span class="success-icon">📺</span><h3>Freundschaftsturnier Brandenburg a.d. Havel</h3><p> 2. Platz </p></div>
  </div>
</section>

<section class="container">

    <h2>📰 Presse & Medien</h2>

    <p class="section-text">
        Unsere Erfolge finden nicht nur auf der Bühne statt – auch regionale Medien berichten regelmäßig über das Forster Männerballett.
    </p>

    <div class="media-grid">

        <a
            href="https://www.radiocottbus.de/2026/06/02/forster-maennerballett-sichert-sich-platz-drei-bei-den-deutschen-meisterschaften/"
            target="_blank"
            rel="noopener noreferrer"
            class="media-card"
        >

            <span class="media-icon">📻</span>

            <h3>Radio Cottbus</h3>

            <p>
                Bericht über unseren Erfolg bei der Deutschen Meisterschaft.
            </p>

            <span class="media-link">
                Beitrag ansehen →
            </span>

        </a>



       <!-- Niederlausitz Aktuell -->
<a
    href="https://www.niederlausitz-aktuell.de/niederlausitz-aktuell/orte/spree-neisse/forst-lausitz/311156/ostdeutscher-vizemeister-und-kostuempreis-fuer-das-forster-maennerballett.html"
    target="_blank"
    rel="noopener noreferrer"
    class="media-card"
>

    <span class="media-icon">📰</span>

    <h3>Niederlausitz Aktuell</h3>

    <p>
        Bericht über unseren Titel als Ostdeutscher Vizemeister.
    </p>

    <span class="media-link">
        📰 Artikel lesen →
    </span>

</a>

<!-- Forster Woche -->
<a
    href="https://fowo.info/2026/03/28/forster-maennerballett-begeistert-mit-alice-im-wunderland/"
    target="_blank"
    rel="noopener noreferrer"
    class="media-card"
>

    <span class="media-icon">🗞️</span>

    <h3>Forster Woche</h3>

    <p>
        Die Forster Woche berichtet über unser aktuelles Showprogramm
        <strong>„Alice im Wunderland“</strong>, unsere Erfolge bei den
        Meisterschaften und den Weg des Forster Männerballetts.
    </p>

    <span class="media-link">
        📰 Artikel lesen →
    </span>

</a>

</div>

</section>

<section class="container">

    <h2>Unsere Tänze</h2>

  <div class="dance-card">
    <img src="/alice-im-wunderland.jpg" alt="Alice im Wunderland" />
    <div class="dance-content">
      <span class="dance-year">2026 / 2027</span>
      <h3>🃏 Alice im Wunderland</h3>
      <p>Eine fantasievolle Reise durch das Wunderland mit beeindruckenden Kostümen und spektakulärer Showchoreografie.</p>
    </div>
  </div>

  <div class="dance-card">
    <img src="/galerie/maennerballett/flyer/neuerTanz.jpg" alt="Neuer Tanz 2026/2027" />
    <div class="dance-content">
      <span class="dance-year">Saison 2026 / 2027</span>
      <span class="secret-badge">🔒 TOP SECRET</span>
      <h3>✨ Unser neuer Tanz</h3>
      <p>Hinter den Kulissen entsteht bereits unsere neue Show für die Saison 2026/27.</p>
      <p>Seid gespannt – schon bald lüften wir das Geheimnis.</p>
    </div>
  </div>
</section>

<Gallery
  title="Bildergalerie"
  images={[
    { src: "/galerie/maennerballett/alice1.jpg", alt: "Alice im Wunderland" },
    { src: "/galerie/maennerballett/alice2.jpg", alt: "Alice im Wunderland" },
    { src: "/galerie/maennerballett/alice3.jpg", alt: "Alice im Wunderland" }
  ]}
/>

</Layout>
