---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Raw Diamonds">

<PageHero
    title="Raw Diamonds"
    subtitle="Power • Ausdruck • Leidenschaft"
    image="/raw-diamonds-header.jpg"
/>

<section class="container">

    <h2>Über Raw Diamonds</h2>

    <p>
        Die Showdancegruppe Raw Diamonds begeistert mit kraftvollen Choreografien,
        modernen Bewegungen und jeder Menge Energie. Gemeinsam entstehen
        abwechslungsreiche Showprogramme, die das Publikum jedes Jahr aufs Neue
        begeistern.
    </p>

</section>

<section class="container">

    <h2>Trainingszeiten</h2>

    <div class="info-box">

        <p><strong>Trainingstag:</strong> Freitag | 20:00 Uhr</p>
        <p><strong>Ort:</strong> ADTV Tanzschule  Fritsche in Cottbus</p>

    </div>

</section>

</Layout>